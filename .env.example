# ============================================================
# Alfredo — Variables de entorno
# ============================================================
# Copiar a .env y completar los valores marcados con CHANGE_ME
# ============================================================

# ── Entorno ──
ENVIRONMENT=development          # development | production
DEBUG=false

# ── Base de datos (app role — respeta RLS, NO es superuser) ──
DATABASE_URL=postgresql+asyncpg://saas_app:CHANGE_ME_app_password@localhost:5432/saas_platform

# ── Base de datos (superuser — para migraciones/seed, bypasea RLS) ──
ADMIN_DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_postgres_password@localhost:5432/saas_platform

# ── PostgreSQL container (solo docker-compose) ──
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=saas_platform
SAAS_APP_USER=saas_app
SAAS_APP_PASSWORD=CHANGE_ME_app_password

# ── Redis (rate limiting, brute-force protection, password reset tokens) ──
REDIS_URL=redis://localhost:6379

# ── JWT ──
# OBLIGATORIO en producción. Generar con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_generate_with_python_secrets

# ── CORS ──
# En producción NO puede ser "*". Separar múltiples orígenes con coma.
CORS_ORIGINS=https://tudominio.com,https://app.tudominio.com

# ── Frontend ──
FRONTEND_URL=https://tudominio.com

# ── MercadoPago ──
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# ── Monitoring (Sentry — https://sentry.io) ──
# Free tier: 5K errors/mes. DSN en Settings → Client Keys
SENTRY_DSN=https://xxxx@o00000.ingest.sentry.io/00000

# ── Email (Resend — https://resend.com) ──
# Free tier: 3,000 emails/mes. API key en https://resend.com/api-keys
RESEND_API_KEY=re_CHANGE_ME
EMAIL_FROM=Alfredo <no-reply@tudominio.com>

# ── Integraciones (opcionales) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
OPENAI_API_KEY=
MERCADOLIBRE_CLIENT_ID=
MERCADOLIBRE_CLIENT_SECRET=
MERCADOLIBRE_REDIRECT_URI=
